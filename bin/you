def cmd_recall(args):
    """Recall relevant memory cards for a conversation query."""
    ensure_system_dirs()
    ensure_user_surface_files()
    index = load_recall_index()
    query = args.query.strip()
    cfg = load_config()
    consent = (not args.no_sensitive) and bool(cfg.get("allow_sensitive_recall", True))

    scored = []
    for memory in index.get("memories", []):
        rel = relevance_score(query, memory)
        level = surface_level(memory, query, consent=consent)
        if rel <= 0 or level <= 0:
            continue
        enriched = dict(memory)
        enriched["relevance"] = rel
        enriched["surface_level"] = max(level, int(memory.get("surface_level", 1)))
        enriched["suggested_surface"] = enriched["surface_level"] >= 2
        enriched["suggested_phrase"] = (
            f"I found a related memory about {enriched.get('title', 'this topic')}. Do you want me to bring it in?"
            if enriched["surface_level"] >= 3
            else f"You've mentioned this before: {enriched.get('title', 'related memory')}."
        )
        scored.append(enriched)

    scored.sort(key=lambda m: (m["relevance"], confidence_rank(m.get("confidence", "low")), m.get("evidence_count", 0)), reverse=True)
    top = scored[:args.limit]

    if top:
        lead = top[0]
        surface_message = (
            f"I found a related memory: {lead.get('title', 'Untitled')}. "
            "Do you want me to open that pattern?"
            if lead.get("surface_level", 0) >= 3
            else f"You've mentioned something similar before. ({lead.get('title', 'pattern')})"
        )
    else:
        surface_message = "No relevant memory was surfaced for this query."

    response = {
        "query": query,
        "memories": top,
        "surface_message": surface_message,
    }

    if args.json:
        print(json.dumps(response, indent=2))
    else:
        print(surface_message)
        for mem in top:
            print(f"- {mem.get('title')} [{mem.get('confidence')}] (surface_level={mem.get('surface_level')})")
    log_operation("recall", {"query": query, "results": len(top), "limit": args.limit, "json": args.json})
    return 0

def cmd_open_loops(args):
    """Read open loops in json or text format."""
    ensure_user_surface_files()
    data = load_open_loops()
    if args.json:
        print(json.dumps(data, indent=2))
    else:
        for loop in data.get("open_loops", []):
            print(f"- {loop.get('id')}: {loop.get('title')} [{loop.get('status')}]")
    return 0

def cmd_watch(args):
    """Poll inbox and process new files automatically."""
    import time
    print(f"👀 Watching Inbox/raw every {args.interval}s (Ctrl+C to stop)")
    try:
        while True:
            raw_files = list(INBOX_RAW_DIR.glob("*.md")) if INBOX_RAW_DIR.exists() else []
            if raw_files:
                cmd_process_inbox(argparse.Namespace(default_energy="=", days=args.days, force_visible=False))
                if args.once:
                    break
            elif args.once:
                break
            time.sleep(args.interval)
    except KeyboardInterrupt:
        print("\nStopped watch mode.")
    return 0

def cmd_demo(args):
    """Run one-command demo on examples/sample-vault."""
    sample = YOU_DIR / "examples" / "sample-vault"
    if not sample.exists():
        print(f"❌ Sample vault not found: {sample}")
        return 1
    print(f"✅ Demo vault ready at: {sample}")
    print("Try:")
    print(f"  YOU_DIR={sample} python3 bin/you recall --query \"investor\" --json")
    return 0

def main():
    parser = argparse.ArgumentParser(
        description="YOU System - Life Intelligence Wiki Operations",
        formatter_class=argparse.RawDescriptionHelpFormatter
    )
    
    subparsers = parser.add_subparsers(dest="command", help="Commands")
    
    # INGEST
    ingest = subparsers.add_parser("ingest", help="Log observation")
    ingest.add_argument("--date", default=datetime.now().strftime("%Y-%m-%d"))
    ingest.add_argument("--event", required=True)
    ingest.add_argument("--energy", default="=", choices=["++", "+", "=", "-", "--"])
    ingest.add_argument("--category", help="Auto-detected if not provided")
    
    # QUERY
    query = subparsers.add_parser("query", help="Synthesize patterns")
    query.add_argument("--categories", nargs="+", required=True)
    
    # PREDICT
    predict = subparsers.add_parser("predict", help="Project future")
    predict.add_argument("--category", required=True)
    predict.add_argument("--months", type=int, default=6)
    
    # LINT
    lint = subparsers.add_parser("lint", help="Health check")
    
    # CAPTURE
    capture = subparsers.add_parser("capture", help="Capture raw note to Inbox/raw")
    capture.add_argument("--source", default="manual")
    capture.add_argument("--text", required=True)

    # PROCESS-INBOX
    process_inbox = subparsers.add_parser("process-inbox", help="Process Inbox/raw into wiki updates")
    process_inbox.add_argument("--default-energy", default="=", choices=["++", "+", "=", "-", "--"])
    process_inbox.add_argument("--days", type=int, default=30)
    process_inbox.add_argument("--force-visible", action="store_true", help="Immediately surface matched categories")

    # REFRESH-AWARENESS
    refresh = subparsers.add_parser("refresh-awareness", help="Rebuild System/AWARENESS.md")
    refresh.add_argument("--days", type=int, default=30)

    # CONTRADICTIONS
    contradictions = subparsers.add_parser("contradictions", help="Generate contradiction hypotheses report")
    contradictions.add_argument("--scan", action="store_true", help="Run contradiction scan")
    contradictions.add_argument("--json", action="store_true", help="Emit JSON output")

    # DAILY-REVIEW
    subparsers.add_parser("daily-review", help="Create daily review note in System/")

    # OBSIDIAN-DASHBOARD
    subparsers.add_parser("obsidian-dashboard", help="Create Dataview dashboard markdown")

    # RECALL
    recall = subparsers.add_parser("recall", help="Recall relevant memories for a conversation query")
    recall.add_argument("--query", required=True)
    recall.add_argument("--limit", type=int, default=5)
    recall.add_argument("--no-sensitive", action="store_true", help="Do not surface medium-sensitivity memories")
    recall.add_argument("--json", action="store_true", help="Return structured JSON payload")

    # OPEN-LOOPS
    open_loops = subparsers.add_parser("open-loops", help="Read open loops")
    open_loops.add_argument("--json", action="store_true", help="Return loops as JSON")

    # WATCH/DAEMON
    watch = subparsers.add_parser("watch", help="Watch Inbox/raw and process automatically")
    watch.add_argument("--interval", type=int, default=15)
    watch.add_argument("--days", type=int, default=30)
    watch.add_argument("--once", action="store_true", help="Run one polling cycle and exit")
    daemon = subparsers.add_parser("daemon", help="Alias for watch mode")
    daemon.add_argument("--interval", type=int, default=15)
    daemon.add_argument("--days", type=int, default=30)
    daemon.add_argument("--once", action="store_true", help="Run one polling cycle and exit")

    # DEMO
    subparsers.add_parser("demo", help="Show one-command demo path")
    
    args = parser.parse_args()
    
    if not args.command:
        parser.print_help()
        return 1
    
    # Ensure YOU_DIR exists
    if not YOU_DIR.exists():
        print(f"❌ YOU directory not found: {YOU_DIR}")
        print("   Run from within ~/YOU or clone the repo first")
        return 1
    
    commands = {
        "ingest": cmd_ingest,
        "query": cmd_query,
        "predict": cmd_predict,
        "lint": cmd_lint,
        "capture": cmd_capture,
        "process-inbox": cmd_process_inbox,
        "refresh-awareness": cmd_refresh_awareness,
        "contradictions": cmd_contradictions,
        "daily-review": cmd_daily_review,
        "obsidian-dashboard": cmd_obsidian_dashboard,
        "recall": cmd_recall,
        "open-loops": cmd_open_loops,
        "watch": cmd_watch,
        "daemon": cmd_watch,
        "demo": cmd_demo,
    }
    
    return commands[args.command](args)

if __name__ == "__main__":
    exit(main())
