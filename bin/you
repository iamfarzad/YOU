#!/usr/bin/env python3
"""
YOU System CLI
Operational layer for Life Intelligence Wiki
"""

import os
import re
import json
import argparse
import shutil
from datetime import datetime, timedelta
from pathlib import Path
from typing import List, Dict, Optional

def resolve_you_dir() -> Path:
    """Resolve YOU directory from env, cwd, or fallback to ~/YOU."""
    env_dir = os.environ.get("YOU_DIR")
    if env_dir:
        return Path(env_dir).expanduser()

    cwd = Path.cwd()
    if (cwd / "SCHEMA.md").exists() and (cwd / "Main Life Categories").exists():
        return cwd

    return Path.home() / "YOU"

YOU_DIR = resolve_you_dir()
CATEGORIES_DIR = YOU_DIR / "Main Life Categories"
INDEX_FILE = YOU_DIR / "index.md"
LOG_FILE = YOU_DIR / "log.md"
INBOX_RAW_DIR = YOU_DIR / "Inbox" / "raw"
INBOX_NORMALIZED_DIR = YOU_DIR / "Inbox" / "normalized"
INBOX_PROCESSED_DIR = YOU_DIR / "Inbox" / "processed"
SYSTEM_DIR = YOU_DIR / "System"
AWARENESS_FILE = SYSTEM_DIR / "AWARENESS.md"
PATTERNS_FILE = SYSTEM_DIR / "PATTERNS.md"
OPEN_LOOPS_FILE = SYSTEM_DIR / "OPEN_LOOPS.md"
CONTRADICTIONS_FILE = SYSTEM_DIR / "CONTRADICTIONS.md"
REVIEW_QUEUE_FILE = SYSTEM_DIR / "REVIEW_QUEUE.md"
FOCUS_FILE = SYSTEM_DIR / "FOCUS.md"
RECALL_INDEX_MD_FILE = SYSTEM_DIR / "RECALL_INDEX.md"
RECALL_INDEX_JSON_FILE = SYSTEM_DIR / "recall_index.json"
OPEN_LOOPS_JSON_FILE = SYSTEM_DIR / "open_loops.json"
TAXONOMY_FILE = SYSTEM_DIR / "TAXONOMY.md"
CATEGORY_RULES_FILE = SYSTEM_DIR / "CATEGORY_RULES.md"
CATEGORY_STATE_FILE = SYSTEM_DIR / "CATEGORY_STATE.json"
CONSENT_FILE = SYSTEM_DIR / "CONSENT.md"
PRIVACY_FILE = SYSTEM_DIR / "PRIVACY.md"
CONFIG_FILE = SYSTEM_DIR / "config.json"
MEMORY_POLICY_FILE = SYSTEM_DIR / "MEMORY_POLICY.md"
SCHEMA_VERSION = "0.1.0"
VISIBLE_DIR = YOU_DIR / "Visible"
EMERGING_DIR = YOU_DIR / "Emerging"
PROFILE_FILE = YOU_DIR / "Profile.md"
CURRENT_NOTES_FILE = YOU_DIR / "Current Notes.md"
RECENT_REFLECTIONS_FILE = YOU_DIR / "Recent Reflections.md"
OPEN_QUESTIONS_FILE = YOU_DIR / "Open Questions.md"
CANVAS_DIR = YOU_DIR / "Canvas"
CANVAS_MAP_FILE = CANVAS_DIR / "YOU Memory Map.canvas"

def ensure_system_dirs():
    """Ensure required inbox/system folders exist."""
    for path in [
        INBOX_RAW_DIR, INBOX_NORMALIZED_DIR, INBOX_PROCESSED_DIR, SYSTEM_DIR, VISIBLE_DIR, EMERGING_DIR, CANVAS_DIR
    ]:
        path.mkdir(parents=True, exist_ok=True)

def ensure_user_surface_files():
    """Ensure minimal user-facing entry pages exist."""
    defaults = {
        PROFILE_FILE: "# Profile\n\n## Identity\n- Add your name or alias.\n\n## Values\n- Add direct values from user-provided input only.\n\n## Goals\n- Add explicit user-stated goals.\n",
        CURRENT_NOTES_FILE: "# Current Notes\n\n- Latest user observations appear here.\n",
        RECENT_REFLECTIONS_FILE: "# Recent Reflections\n\n- This page captures synthesized reflections from recent activity.\n",
        OPEN_QUESTIONS_FILE: "# Open Questions\n\n- Questions to revisit are tracked here.\n",
    }
    for file_path, content in defaults.items():
        if not file_path.exists():
            file_path.write_text(content)
    if not TAXONOMY_FILE.exists():
        TAXONOMY_FILE.write_text(
            "# Taxonomy (Hidden Scaffolding)\n\n"
            "This file holds latent categories (the ontology), not the default user UI.\n"
            "Use `index.md` as canonical source for the full category list.\n"
        )
    if not CATEGORY_RULES_FILE.exists():
        CATEGORY_RULES_FILE.write_text(
            "# Category Rules\n\n"
            "Show category when one of these is true:\n"
            "- 2-3 related observations exist,\n"
            "- user directly names it,\n"
            "- one high-confidence event exists,\n"
            "- it bridges already-visible areas.\n"
        )
    if not RECALL_INDEX_MD_FILE.exists():
        RECALL_INDEX_MD_FILE.write_text(
            "# Recall Index\n\n"
            "Short memory cards for conversation-time retrieval.\n"
            "Each card must be relevance-filtered, confidence-labeled, and source-linked.\n"
        )
    if not FOCUS_FILE.exists():
        FOCUS_FILE.write_text(
            "# Focus Nodes\n\n"
            f"updated: {datetime.now().strftime('%Y-%m-%d')}\n\n"
            "## Current focus\n- (none yet)\n\n"
            "## Why these are highlighted\n- Focus is assigned from visual importance and recency.\n"
        )
    if not RECALL_INDEX_JSON_FILE.exists():
        RECALL_INDEX_JSON_FILE.write_text(json.dumps({
            "schema_version": SCHEMA_VERSION,
            "memories": []
        }, indent=2) + "\n")
    if not OPEN_LOOPS_JSON_FILE.exists():
        OPEN_LOOPS_JSON_FILE.write_text(json.dumps({
            "schema_version": SCHEMA_VERSION,
            "open_loops": []
        }, indent=2) + "\n")
    if not CONFIG_FILE.exists():
        CONFIG_FILE.write_text(json.dumps({
            "schema_version": SCHEMA_VERSION,
            "auto_capture": False,
            "allow_sensitive_recall": True,
            "allow_profile_updates_without_review": False,
            "allow_remote_llm_processing": False,
            "default_memory_surface_level": 2,
            "private_categories": ["Mental Health", "Relationships", "Finance"]
        }, indent=2) + "\n")
    if not MEMORY_POLICY_FILE.exists():
        MEMORY_POLICY_FILE.write_text(
            "# Memory Policy\n\n"
            "| Memory type | Auto-write? | User confirmation |\n"
            "|---|---:|---:|\n"
            "| Raw note | yes | no |\n"
            "| Project fact | yes | optional |\n"
            "| User preference | yes | optional |\n"
            "| Profile identity fact | no | yes |\n"
            "| Health/wellbeing hypothesis | no | yes |\n"
            "| Relationship hypothesis | no | yes |\n"
            "| Future hypothesis | yes | review queue |\n"
            "| Sensitive category activation | no | yes |\n"
            "| Deletion | no | yes |\n"
        )
    if not CONSENT_FILE.exists():
        CONSENT_FILE.write_text(
            "# Consent\n\n"
            "- Sensitive recall allowed: true\n"
            "- Profile updates require review: true\n"
            "- Remote model processing allowed: false\n"
        )
    if not PRIVACY_FILE.exists():
        PRIVACY_FILE.write_text(
            "# Privacy\n\n"
            "YOU-memory is local-first. Avoid sending sensitive memory to remote services unless explicitly enabled in `System/config.json`.\n"
        )
    if not CANVAS_MAP_FILE.exists():
        CANVAS_MAP_FILE.write_text('{"nodes":[],"edges":[]}')

def load_category_state() -> Dict:
    if CATEGORY_STATE_FILE.exists():
        try:
            data = json.loads(CATEGORY_STATE_FILE.read_text())
            if "schema_version" not in data:
                data["schema_version"] = SCHEMA_VERSION
            if "categories" not in data:
                # Backward compatibility with old flat format
                categories = {k: v for k, v in data.items() if isinstance(v, dict)}
                data = {"schema_version": SCHEMA_VERSION, "categories": categories}
            return data
        except json.JSONDecodeError:
            return {"schema_version": SCHEMA_VERSION, "categories": {}}
    return {"schema_version": SCHEMA_VERSION, "categories": {}}

def save_category_state(state: Dict):
    state["schema_version"] = SCHEMA_VERSION
    CATEGORY_STATE_FILE.write_text(json.dumps(state, indent=2, sort_keys=True) + "\n")

def normalize_category_name(category: str) -> str:
    mapping = {
        "work": "Work",
        "mental_health": "Mental Health",
        "sleep": "Sleep Patterns",
        "relationships": "Relationships",
        "finance": "Finance",
        "physical_health": "Physical Health",
    }
    key = category.lower().replace(" ", "_")
    return mapping.get(key, category.replace("_", " ").title())

def compute_activation_score(evidence_count: int, intensity: int = 0, cross_links: int = 0,
                             user_confirmation: int = 0, contradiction_penalty: int = 0) -> int:
    recency_weight = 1 if evidence_count > 0 else 0
    return evidence_count + recency_weight + intensity + cross_links + user_confirmation - contradiction_penalty

def compute_visual_importance(evidence_count: int, recent_activity: int, cross_links: int,
                              open_loop_weight: int = 0, emotional_intensity: int = 0,
                              user_pin: int = 0, stale_penalty: int = 0) -> int:
    return evidence_count + recent_activity + cross_links + open_loop_weight + emotional_intensity + user_pin - stale_penalty

def append_if_missing(file_path: Path, text: str):
    content = file_path.read_text() if file_path.exists() else ""
    if text not in content:
        suffix = "\n" if content.endswith("\n") or content == "" else "\n\n"
        file_path.write_text(content + suffix + text + "\n")

def load_recall_index() -> Dict:
    if not RECALL_INDEX_JSON_FILE.exists():
        return {"schema_version": SCHEMA_VERSION, "memories": []}
    try:
        data = json.loads(RECALL_INDEX_JSON_FILE.read_text())
    except json.JSONDecodeError:
        return {"schema_version": SCHEMA_VERSION, "memories": []}
    if "schema_version" not in data:
        data["schema_version"] = SCHEMA_VERSION
    if "memories" not in data or not isinstance(data["memories"], list):
        data["memories"] = []
    return data

def save_recall_index(index: Dict):
    index["schema_version"] = SCHEMA_VERSION
    RECALL_INDEX_JSON_FILE.write_text(json.dumps(index, indent=2, sort_keys=True) + "\n")

def token_set(text: str) -> set:
    return set(re.findall(r"[a-zA-Z0-9_]+", text.lower()))

def relevance_score(query: str, memory: Dict) -> int:
    q_tokens = token_set(query)
    if not q_tokens:
        return 0
    hay = " ".join([
        memory.get("title", ""),
        memory.get("summary", ""),
        " ".join(memory.get("tags", [])),
    ])
    h_tokens = token_set(hay)
    return len(q_tokens.intersection(h_tokens))

def infer_sensitivity(memory: Dict) -> str:
    text = " ".join([memory.get("title", ""), memory.get("summary", "")]).lower()
    if any(w in text for w in ["health", "anxiety", "fear", "relationship", "therapy"]):
        return "medium"
    return "low"

def confidence_rank(level: str) -> int:
    return {"low": 1, "medium": 2, "high": 3}.get(level, 1)

def surface_level(memory: Dict, query: str, consent: bool = True) -> int:
    rel = relevance_score(query, memory)
    conf = confidence_rank(memory.get("confidence", "low"))
    sensitivity = infer_sensitivity(memory)
    evidence = int(memory.get("evidence_count", 1))
    if rel == 0:
        return 0
    if sensitivity == "medium" and not consent:
        return 0
    if conf <= 1 and evidence <= 1:
        return 1
    if conf == 2 and evidence >= 2:
        return 2
    if conf >= 2 and sensitivity == "medium":
        return 3
    return 2

def load_config() -> Dict:
    ensure_user_surface_files()
    try:
        return json.loads(CONFIG_FILE.read_text())
    except json.JSONDecodeError:
        return {
            "schema_version": SCHEMA_VERSION,
            "allow_sensitive_recall": True,
            "default_memory_surface_level": 2
        }

def load_open_loops() -> Dict:
    if not OPEN_LOOPS_JSON_FILE.exists():
        return {"schema_version": SCHEMA_VERSION, "open_loops": []}
    try:
        data = json.loads(OPEN_LOOPS_JSON_FILE.read_text())
    except json.JSONDecodeError:
        return {"schema_version": SCHEMA_VERSION, "open_loops": []}
    if "open_loops" not in data:
        data["open_loops"] = []
    data["schema_version"] = data.get("schema_version", SCHEMA_VERSION)
    return data

def save_open_loops(data: Dict):
    data["schema_version"] = SCHEMA_VERSION
    OPEN_LOOPS_JSON_FILE.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n")

def refresh_focus_from_state(state: Dict):
    categories = state.get("categories", {})
    ranked = sorted(
        [(name, meta) for name, meta in categories.items() if isinstance(meta, dict)],
        key=lambda item: item[1].get("importance", 0),
        reverse=True
    )[:5]
    lines = [
        "# Focus Nodes",
        "",
        f"updated: {datetime.now().strftime('%Y-%m-%d %H:%M')}",
        "",
        "## Current focus",
    ]
    if ranked:
        for name, meta in ranked:
            lines.append(f"- [[{name}]] (importance={meta.get('importance', 0)}, confidence={meta.get('confidence', 'low')})")
    else:
        lines.append("- (none yet)")
    lines.extend([
        "",
        "## Why these are highlighted",
        "- High recent activity and cross-link influence.",
        "- Open-loop impact and emotional intensity weighting.",
        "",
        "## Suggested next review",
        "- Confirm whether the top focus node should remain pinned.",
    ])
    FOCUS_FILE.write_text("\n".join(lines) + "\n")

def get_category_path(category_name: str) -> Optional[Path]:
    """Find category directory by fuzzy matching"""
    category_lower = category_name.lower().replace("_", " ")
    
    if not CATEGORIES_DIR.exists():
        return None
    
    for dir_name in os.listdir(CATEGORIES_DIR):
        dir_path = CATEGORIES_DIR / dir_name
        if not dir_path.is_dir():
            continue
        dir_lower = dir_name.lower()
        if category_lower in dir_lower or dir_lower in category_lower:
            return dir_path
    return None

def find_main_file(category_path: Path) -> Optional[Path]:
    """Find the main markdown file in a category"""
    md_files = list(category_path.glob("*.md"))
    if not md_files:
        return None
    
    # Prefer overview/main files
    for f in md_files:
        if "overview" in f.name.lower() or "main" in f.name.lower():
            return f
    
    # Return first markdown file
    return md_files[0]

def parse_activity_log(content: str) -> List[Dict]:
    """Extract activity log entries from markdown"""
    entries = []
    # Match table rows: | Date | Event | Energy | Cross-impact |
    pattern = r"\|\s*(\d{4}-\d{2}-\d{2})\s*\|\s*(.+?)\s*\|\s*([\-+]{0,2})\s*\|"
    matches = re.findall(pattern, content)
    for date, event, energy in matches:
        entries.append({
            "date": date,
            "event": event.strip(),
            "energy": energy if energy else "="
        })
    return entries

def update_activity_log(file_path: Path, date: str, event: str, energy: str = "=") -> bool:
    """Add entry to Activity Log section"""
    content = file_path.read_text()
    
    # Find Current section
    current_match = re.search(r"## Current\s*\n(.*?)(?=## Future|$)", content, re.DOTALL)
    if not current_match:
        return False
    
    # Find or create Activity Log table
    table_pattern = r"(## Current.*?)(\| Date \| Event/Entry \| Energy \| Cross-Impact \|\n\|------\|-------------\|--------\|--------------\|\n)(.*?)(?=###|##|$)"
    table_match = re.search(table_pattern, content, re.DOTALL)
    
    new_entry = f"| {date} | {event} | {energy} | |\n"
    
    if table_match:
        # Insert after header row
        content = content.replace(
            table_match.group(2),
            table_match.group(2) + new_entry
        )
    else:
        # Create new table
        table = f"\n### Activity Log\n\n| Date | Event/Entry | Energy | Cross-Impact |\n|------|-------------|--------|--------------|\n{new_entry}\n"
        content = content.replace(
            current_match.group(0),
            current_match.group(0) + table
        )
    
    file_path.write_text(content)
    return True

def log_operation(operation: str, details: Dict):
    """Append to log.md"""
    if not LOG_FILE.exists():
        LOG_FILE.write_text("# YOU System Log\n\n")
    
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    entry = f"## [{timestamp}] {operation}\n\n"
    entry += json.dumps(details, indent=2)
    entry += "\n\n---\n\n"
    
    content = LOG_FILE.read_text()
    # Insert after header
    lines = content.split("\n")
    lines.insert(2, entry)
    LOG_FILE.write_text("\n".join(lines))

def build_awareness_snapshot(days: int = 30) -> str:
    """Build compressed awareness snapshot from recent logs and system state."""
    cutoff = datetime.now() - timedelta(days=days)
    recent_entries: List[Dict] = []
    category_counter: Dict[str, int] = {}
    negative_count = 0
    positive_count = 0

    for category_dir in os.listdir(CATEGORIES_DIR) if CATEGORIES_DIR.exists() else []:
        category_path = CATEGORIES_DIR / category_dir
        if not category_path.is_dir():
            continue
        main_file = find_main_file(category_path)
        if not main_file:
            continue

        entries = parse_activity_log(main_file.read_text())
        for entry in entries:
            try:
                entry_dt = datetime.strptime(entry["date"], "%Y-%m-%d")
            except ValueError:
                continue
            if entry_dt < cutoff:
                continue
            recent_entries.append({
                "category": category_dir,
                **entry
            })
            category_counter[category_dir] = category_counter.get(category_dir, 0) + 1
            if "-" in entry["energy"]:
                negative_count += 1
            if "+" in entry["energy"]:
                positive_count += 1

    state = load_category_state()
    categories_state = state.get("categories", {})
    visible_categories = [name for name, meta in categories_state.items() if isinstance(meta, dict) and meta.get("visible")]
    top_categories = sorted(category_counter.items(), key=lambda x: x[1], reverse=True)[:5]
    top_list = "\n".join([f"- {name}: {count} entries in last {days} days." for name, count in top_categories]) or "- No recent category activity found."

    patterns = []
    if negative_count > positive_count:
        patterns.append("| Negative energy trend | More negative than positive entries in recent activity | medium | active |")
    if positive_count >= negative_count and (positive_count + negative_count) > 0:
        patterns.append("| Recovery trend | Positive/neutral momentum is not worse than negatives | low-medium | observe |")
    patterns_table = "\n".join(patterns) if patterns else "| Pattern signal pending | Not enough recent energy data | low | needs data |"

    open_loops = []
    if OPEN_LOOPS_FILE.exists():
        lines = [ln.strip() for ln in OPEN_LOOPS_FILE.read_text().splitlines() if ln.strip().startswith("- ")]
        open_loops.extend(lines[:5])
    if not open_loops:
        open_loops = ["- No explicit open loops recorded. Use `you daily-review` to add one."]

    watchlist = [
        f"- Burnout risk: {'medium' if negative_count >= 3 else 'low'}",
        "- Relationship spillover: unknown",
        "- Recovery habits: needs more consistent logging",
    ]

    next_question = "What changed after the most recent high-stress event?"

    visible_summary = ", ".join(visible_categories[:8]) if visible_categories else "None yet"
    focus_preview = ""
    if FOCUS_FILE.exists():
        focus_lines = [ln.strip() for ln in FOCUS_FILE.read_text().splitlines() if ln.strip().startswith("- [[")]
        if focus_lines:
            focus_preview = "\n## Focus preview\n" + "\n".join(focus_lines[:3]) + "\n"

    return f"""# YOU Awareness Snapshot
updated: {datetime.now().strftime("%Y-%m-%d %H:%M")}

## Current state
- Recent entries analyzed: {len(recent_entries)} (last {days} days)
- Energy balance: +{positive_count} / -{negative_count}
- Visible categories: {visible_summary}
{top_list}

## Active patterns
| Pattern | Evidence | Confidence | Status |
|---|---|---|---|
{patterns_table}

## Open loops
{chr(10).join(open_loops)}

## Watchlist
{chr(10).join(watchlist)}

## Next useful question
"{next_question}"
{focus_preview}
"""

def refresh_awareness(days: int = 30) -> Path:
    """Write awareness snapshot to System/AWARENESS.md."""
    ensure_system_dirs()
    ensure_user_surface_files()
    AWARENESS_FILE.write_text(build_awareness_snapshot(days=days))
    return AWARENESS_FILE

def cmd_ingest(args):
    """INGEST: Log observation to category"""
    category = args.category or infer_category(args.event)
    category_path = get_category_path(category)
    
    if not category_path:
        print(f"❌ Category not found: {category}")
        return 1
    
    main_file = find_main_file(category_path)
    if not main_file:
        print(f"❌ No files in category: {category}")
        return 1
    
    success = update_activity_log(
        main_file,
        args.date,
        args.event,
        args.energy
    )
    
    if success:
        print(f"✅ Logged to {category}/{main_file.name}")
        log_operation("ingest", {
            "category": category,
            "file": str(main_file),
            "date": args.date,
            "event": args.event,
            "energy": args.energy
        })
        return 0
    else:
        print("❌ Failed to update Activity Log")
        return 1

def infer_category(event: str) -> str:
    """Infer category from event text"""
    keywords = {
        "work": ["manager", "meeting", "deadline", "project", "client", "colleague", "promotion"],
        "mental_health": ["anxiety", "stress", "therapy", "depressed", "mood", "feeling"],
        "sleep": ["insomnia", "tired", "couldn't sleep", "woke up", "bedtime"],
        "relationships": ["partner", "spouse", "dating", "argument", "breakup"],
        "finance": ["money", "bill", "expensive", "budget", "debt", "saving"],
        "physical_health": ["exercise", "gym", "workout", "running", "sick", "doctor"],
    }
    
    event_lower = event.lower()
    for category, words in keywords.items():
        if any(word in event_lower for word in words):
            return category
    
    return "mental_health"  # default

def cmd_query(args):
    """QUERY: Synthesize patterns across categories"""
    categories = args.categories or []
    if not categories:
        print("❌ No categories specified")
        return 1
    
    results = []
    for category in categories:
        category_path = get_category_path(category)
        if not category_path:
            continue
        
        main_file = find_main_file(category_path)
        if not main_file:
            continue
        
        content = main_file.read_text()
        entries = parse_activity_log(content)
        
        results.append({
            "category": category,
            "file": str(main_file),
            "entries": entries
        })
    
    # Find cross-category patterns
    print("\n" + "="*60)
    print("QUERY RESULTS")
    print("="*60)
    
    total_entries = sum(len(r["entries"]) for r in results)
    print(f"\nFound {total_entries} entries across {len(results)} categories")
    
    for result in results:
        print(f"\n📁 {result['category']}")
        print(f"   File: {result['file']}")
        if result['entries']:
            recent = result['entries'][-3:] if len(result['entries']) > 3 else result['entries']
            for entry in recent:
                print(f"   • {entry['date']}: {entry['event']} [{entry['energy']}]")
        else:
            print("   (No entries)")
    
    # Surface cross-category connections
    if len(results) > 1:
        print("\n🔗 Cross-category connections:")
        print("   Events in these categories may influence each other")
        print("   → Check Future sections for projected cascade effects")
    
    log_operation("query", {
        "categories": categories,
        "results_count": len(results),
        "total_entries": total_entries
    })
    
    return 0

def cmd_predict(args):
    """PREDICT: Project future trajectories"""
    category = args.category
    months = args.months
    
    category_path = get_category_path(category)
    if not category_path:
        print(f"❌ Category not found: {category}")
        return 1
    
    main_file = find_main_file(category_path)
    if not main_file:
        print(f"❌ No files in category: {category}")
        return 1
    
    content = main_file.read_text()
    entries = parse_activity_log(content)
    
    # Calculate metrics
    if not entries:
        print(f"\n📊 {category}: No data to project from")
        return 0
    
    recent = [e for e in entries if e['date'] > (datetime.now() - timedelta(days=30)).strftime("%Y-%m-%d")]
    negative = len([e for e in recent if '-' in e['energy']])
    positive = len([e for e in recent if '+' in e['energy']])
    
    # Extract satisfaction from Current section
    satisfaction_match = re.search(r"satisfaction: \[(\d+)\]/10", content)
    satisfaction = int(satisfaction_match.group(1)) if satisfaction_match else 5
    
    print("\n" + "="*60)
    print(f"PREDICTION: {category.upper()}")
    print("="*60)
    
    print(f"\n📊 Current State:")
    print(f"   Entries (30d): {len(recent)}")
    print(f"   Negative: {negative}")
    print(f"   Positive: {positive}")
    print(f"   Satisfaction: {satisfaction}/10")
    
    print(f"\n🔮 Projection ({months} months):")
    
    if satisfaction < 4 and negative > 2:
        print("   ⚠️  TRAJECTORY: DECLINING")
        print("   If unaddressed:")
        print(f"   → {months//3} mo: Continued degradation")
        print(f"   → {months//2} mo: Likely affecting adjacent categories")
        print(f"   → {months} mo: Significant quality of life impact")
        print("\n   💡 Recommended: Update 'Future → With attention' section")
    elif satisfaction > 7 and positive > negative:
        print("   ✅ TRAJECTORY: IMPROVING")
        print("   Maintaining current path:")
        print(f"   → {months//3} mo: Building positive momentum")
        print(f"   → {months} mo: Strong position")
    else:
        print("   ➖ TRAJECTORY: STABLE")
        print("   No significant change expected without intervention")
    
    # Check Future section for existing projection
    future_match = re.search(r"## Future.*?(?=## |$)", content, re.DOTALL)
    if future_match:
        print("\n📄 Current Future section exists:")
        print("   Review and update based on recent entries")
    
    log_operation("predict", {
        "category": category,
        "months": months,
        "satisfaction": satisfaction,
        "entries_30d": len(recent)
    })
    
    return 0

def cmd_lint(args):
    """LINT: Health check wiki"""
    issues = {
        "orphan": [],
        "stale": [],
        "empty": [],
        "memory_safety": []
    }
    
    all_md = list(YOU_DIR.rglob("*.md"))
    now = datetime.now()
    
    print("\n" + "="*60)
    print("LINT: Wiki Health Check")
    print("="*60)
    
    for md_file in all_md:
        content = md_file.read_text()
        rel_path = md_file.relative_to(YOU_DIR)
        
        # Check orphans (no up:: link)
        if "up:: [[" not in content and md_file.name not in ["YOU.md", "index.md", "log.md", "README.md"]:
            issues["orphan"].append(str(rel_path))
        
        # Check staleness
        entries = parse_activity_log(content)
        if entries:
            latest = max(e['date'] for e in entries)
            latest_date = datetime.strptime(latest, "%Y-%m-%d")
            if (now - latest_date).days > 180:
                issues["stale"].append({
                    "file": str(rel_path),
                    "last_entry": latest
                })

    # Memory safety checks
    recall_index = load_recall_index()
    for mem in recall_index.get("memories", []):
        if mem.get("type") in ["hypothesis", "pattern"] and mem.get("status") == "confirmed":
            issues["memory_safety"].append(f"{mem.get('id')}: hypothesis/pattern marked confirmed")
        if not mem.get("source_ids"):
            issues["memory_safety"].append(f"{mem.get('id')}: missing source_ids")
        if mem.get("sensitivity") == "medium" and int(mem.get("surface_level", 0)) < 3:
            issues["memory_safety"].append(f"{mem.get('id')}: sensitive memory with low surface_level")
    
    # Check empty categories
    for category in os.listdir(CATEGORIES_DIR) if CATEGORIES_DIR.exists() else []:
        cat_path = CATEGORIES_DIR / category
        if cat_path.is_dir():
            md_count = len(list(cat_path.glob("*.md")))
            if md_count == 0:
                issues["empty"].append(category)
    
    print(f"\n📊 Summary:")
    print(f"   Total files: {len(all_md)}")
    print(f"   Orphan files: {len(issues['orphan'])}")
    print(f"   Stale files (>6mo): {len(issues['stale'])}")
    print(f"   Empty categories: {len(issues['empty'])}")
    print(f"   Memory safety issues: {len(issues['memory_safety'])}")
    
    if issues['orphan']:
        print(f"\n⚠️  Orphan files (no up:: link):")
        for f in issues['orphan'][:5]:
            print(f"   • {f}")
    
    if issues['stale']:
        print(f"\n⏰ Stale files:")
        for item in issues['stale'][:5]:
            print(f"   • {item['file']} (last: {item['last_entry']})")

    if issues['memory_safety']:
        print("\n🛡️  Memory safety:")
        for item in issues['memory_safety'][:5]:
            print(f"   • {item}")
    
    print("\n✅ Lint complete")
    
    log_operation("lint", {
        "total_files": len(all_md),
        "orphan_count": len(issues['orphan']),
        "stale_count": len(issues['stale']),
        "memory_safety_count": len(issues['memory_safety'])
    })
    
    return 0

def cmd_capture(args):
    """CAPTURE: store raw signal in Inbox/raw as YAML-like record."""
    ensure_system_dirs()
    stamp = datetime.now().strftime("%Y-%m-%dT%H-%M-%S")
    file_path = INBOX_RAW_DIR / f"{stamp}_{args.source}.md"
    created = datetime.now().strftime("%Y-%m-%d %H:%M")
    content = (
        f"id: {stamp}_{args.source}\n"
        f"source: {args.source}\n"
        f"created: {created}\n"
        f"raw_text: {json.dumps(args.text)}\n"
        "processed: false\n"
    )
    file_path.write_text(content)
    print(f"✅ Captured raw entry: {file_path}")
    log_operation("capture", {"source": args.source, "file": str(file_path), "created": created})
    return 0

def parse_raw_note(file_path: Path) -> Dict:
    """Read simple key/value raw note format."""
    data: Dict[str, str] = {}
    for line in file_path.read_text().splitlines():
        if ":" not in line:
            continue
        key, value = line.split(":", 1)
        data[key.strip()] = value.strip().strip('"')
    return data

def cmd_process_inbox(args):
    """PROCESS-INBOX: raw -> normalized -> ingest -> archive."""
    ensure_system_dirs()
    ensure_user_surface_files()
    state = load_category_state()
    categories_state = state.get("categories", {})
    recall_index = load_recall_index()
    loops_data = load_open_loops()
    raw_files = sorted(INBOX_RAW_DIR.glob("*.md"))
    if not raw_files:
        print("ℹ️ No raw inbox items found")
        return 0

    processed_count = 0
    for raw_file in raw_files:
        data = parse_raw_note(raw_file)
        if data.get("processed", "false").lower() == "true":
            continue

        source_id = data.get("id") or f"src_{datetime.now().strftime('%Y_%m_%d_%H%M%S')}_{args.source if hasattr(args, 'source') else 'raw'}"
        raw_text = data.get("raw_text", "")
        event = raw_text.strip('"')
        detected_category = normalize_category_name(infer_category(event))
        energy = args.default_energy
        lower_event = event.lower()
        if any(word in lower_event for word in ["tired", "anxiety", "stress", "worried", "insomnia"]):
            energy = "-"
        elif any(word in lower_event for word in ["great", "productive", "calm", "energized"]):
            energy = "+"

        date = datetime.now().strftime("%Y-%m-%d")
        observation_id = f"obs_{date.replace('-', '_')}_{processed_count+1:03d}"
        normalized = (
            f"schema_version: {SCHEMA_VERSION}\n"
            f"source_id: {source_id}\n"
            f"observation_id: {observation_id}\n"
            f"date: {date}\n"
            f"event: {json.dumps(event)}\n"
            f"source_quote: {json.dumps(event)}\n"
            f"energy: {energy}\n"
            f"possible_categories:\n"
            f"  - {detected_category}\n"
            "confidence: medium\n"
            "needs_user_confirmation: false\n"
        )
        normalized_file = INBOX_NORMALIZED_DIR / raw_file.name
        normalized_file.write_text(normalized)

        # Keep user-facing experience minimal: log to Current Notes first.
        current_notes = CURRENT_NOTES_FILE.read_text()
        note_line = f"- {date}: {event} [{energy}]"
        if note_line not in current_notes:
            CURRENT_NOTES_FILE.write_text(current_notes.rstrip() + "\n" + note_line + "\n")

        category_meta = categories_state.get(detected_category, {
            "visible": False,
            "evidence_count": 0,
            "last_seen": date,
            "confidence": "low",
            "status": "latent",
            "needs_user_confirmation": False,
            "node_type": "category",
            "importance": 0,
            "pinned": False,
            "review_status": "needs_user_confirmation",
        })
        category_meta["evidence_count"] = int(category_meta.get("evidence_count", 0)) + 1
        category_meta["last_seen"] = date
        category_meta["confidence"] = "medium" if category_meta["evidence_count"] >= 3 else "low"
        category_meta["status"] = "tracked"

        intensity = 1 if energy in ["-", "--"] else 0
        activation_score = compute_activation_score(
            evidence_count=category_meta["evidence_count"],
            intensity=intensity,
            cross_links=0,
            user_confirmation=1 if category_meta.get("user_confirmed") else 0,
            contradiction_penalty=0
        )
        category_meta["activation_score"] = activation_score
        category_meta["recent_activity"] = int(category_meta.get("recent_activity", 0)) + 1
        category_meta["cross_links"] = int(category_meta.get("cross_links", 0))
        category_meta["color_group"] = "work" if detected_category == "Work" else "general"
        category_meta["sensitivity"] = "medium" if detected_category in ["Mental Health", "Sleep Patterns", "Relationships"] else "low"
        category_meta["energy"] = "negative" if "-" in energy else "positive"
        category_meta["importance"] = compute_visual_importance(
            evidence_count=category_meta["evidence_count"],
            recent_activity=category_meta.get("recent_activity", 0),
            cross_links=category_meta.get("cross_links", 0),
            open_loop_weight=1 if "need to" in lower_event else 0,
            emotional_intensity=1 if energy in ["-", "--"] else 0,
            user_pin=1 if category_meta.get("pinned") else 0,
            stale_penalty=0
        )
        if category_meta["importance"] >= 8:
            category_meta["node_type"] = "focus"
            category_meta["status"] = "active"

        if activation_score >= 6 or args.force_visible:
            category_meta["visible"] = True
            category_meta["status"] = "active"
            visible_file = VISIBLE_DIR / f"{detected_category}.md"
            category_group = detected_category.lower().replace(" ", "_")
            if not visible_file.exists():
                visible_file.write_text(
                    "---\n"
                    "type: memory_node\n"
                    f"status: {category_meta['status']}\n"
                    f"node_type: {category_meta.get('node_type', 'category')}\n"
                    f"category_group: {category_group}\n"
                    f"importance: {category_meta.get('importance', 1)}\n"
                    f"confidence: {category_meta['confidence']}\n"
                    f"energy: {category_meta.get('energy', 'neutral')}\n"
                    f"last_seen: {date}\n"
                    f"evidence_count: {category_meta['evidence_count']}\n"
                    f"surface_level: {max(2, activation_score // 2)}\n"
                    f"color_group: {category_meta.get('color_group', 'general')}\n"
                    f"review_status: {category_meta.get('review_status', 'needs_user_confirmation')}\n"
                    f"pinned: {str(category_meta.get('pinned', False)).lower()}\n"
                    "tags:\n"
                    f"  - you-memory\n  - node/{category_meta.get('node_type', 'category')}\n  - state/{category_meta['status']}\n  - confidence/{category_meta['confidence']}\n"
                    "---\n\n"
                    f"# {detected_category}\n\n"
                    "## Why this appeared\n"
                    f"This page was created because repeated recent observations matched **{detected_category}**.\n\n"
                    "## Observations\n"
                    "## Current hypothesis\n"
                    f"[Hypothesis] {detected_category} may be impacting current quality-of-life dynamics.\n\n"
                    f"Confidence: {category_meta['confidence']}\n"
                    "Needs confirmation: yes\n"
                )
            append_if_missing(visible_file, f"- {date}: {event} [{energy}]")
        elif activation_score >= 4:
            append_if_missing(REVIEW_QUEUE_FILE, f"- [{detected_category}] score {activation_score}: {event}")

        categories_state[detected_category] = category_meta

        memory_type = "pattern" if category_meta["evidence_count"] >= 2 else "observation"
        memory_id = f"mem_{date.replace('-', '_')}_{processed_count+1:03d}_{detected_category.lower().replace(' ', '_')}"
        memory = {
            "id": memory_id,
            "type": memory_type,
            "title": f"{detected_category} signal",
            "summary": f"{event}",
            "status": "active" if category_meta.get("visible") else "needs_review",
            "confidence": category_meta["confidence"],
            "sensitivity": "medium" if detected_category in ["Mental Health", "Sleep Patterns", "Relationships"] else "low",
            "surface_level": 2,
            "time_layer": "present",
            "categories": [detected_category],
            "source_ids": [source_id],
            "source_quotes": [event],
            "created": date,
            "last_seen": date,
            "reviewed": False,
            "tags": [detected_category.lower().replace(" ", "_"), "inbox"],
            "evidence_count": category_meta["evidence_count"],
            "source_links": [str(normalized_file.relative_to(YOU_DIR))]
        }
        if not any(m.get("id") == memory_id for m in recall_index["memories"]):
            recall_index["memories"].append(memory)

        # Emergent category suggestion (safe, optional)
        emergent_keywords = ["unreliable", "delay", "shame", "avoiding admin", "trusted"]
        if sum(1 for kw in emergent_keywords if kw in lower_event) >= 2:
            emergent_name = "Reliability Anxiety"
            suggestion_file = EMERGING_DIR / f"Suggested - {emergent_name}.md"
            if not suggestion_file.exists():
                suggestion_file.write_text(
                    f"# Suggested Category: {emergent_name}\n\n"
                    "## Why this may matter\n"
                    "[Hypothesis] Multiple entries indicate concern about being perceived as unreliable.\n\n"
                    "## Evidence\n"
                    "## Suggested links\n"
                    "- [[Work]]\n- [[Relationships]]\n- [[Self-image]]\n- [[Avoidance]]\n\n"
                    "## User decision\n"
                    "- [ ] Accept\n- [ ] Rename\n- [ ] Reject\n- [ ] Merge into another category\n"
                )
            append_if_missing(suggestion_file, f"- {date}: {event}")
            categories_state[emergent_name] = {
                "visible": False,
                "evidence_count": int(categories_state.get(emergent_name, {}).get("evidence_count", 0)) + 1,
                "last_seen": date,
                "confidence": "low",
                "status": "suggested_new_category",
                "needs_user_confirmation": True,
            }

        if "TODO" in event or "need to" in lower_event or "next step" in lower_event:
            loop_id = f"loop_{date.replace('-', '_')}_{processed_count+1:03d}"
            if not any(lp.get("id") == loop_id for lp in loops_data.get("open_loops", [])):
                loops_data.setdefault("open_loops", []).append({
                    "id": loop_id,
                    "title": event[:80],
                    "status": "open",
                    "created": date,
                    "last_seen": date,
                    "related_memories": [memory_id],
                    "next_action": "Review in next session",
                    "owner": "user"
                })

        archived = INBOX_PROCESSED_DIR / raw_file.name
        shutil.move(str(raw_file), archived)
        processed_count += 1

    state["categories"] = categories_state
    save_category_state(state)
    refresh_focus_from_state(state)
    save_recall_index(recall_index)
    save_open_loops(loops_data)
    awareness_path = refresh_awareness(days=args.days)
    print(f"✅ Processed {processed_count} inbox item(s)")
    print(f"✅ Refreshed awareness: {awareness_path}")
    log_operation("process-inbox", {"processed_count": processed_count, "days": args.days})
    return 0

def cmd_refresh_awareness(args):
    """Refresh compressed system awareness snapshot."""
    file_path = refresh_awareness(days=args.days)
    print(f"✅ Awareness refreshed: {file_path}")
    log_operation("refresh-awareness", {"file": str(file_path), "days": args.days})
    return 0

def cmd_contradictions(args):
    """Build contradiction report from simple heuristics."""
    ensure_system_dirs()
    contradictions = [
        "# Contradictions",
        "",
        f"updated: {datetime.now().strftime('%Y-%m-%d %H:%M')}",
        "",
        "## Detected",
    ]

    checks = [
        ("Main Life Categories/Goals & Aspirations/Goals_Aspirations.md", "Main Life Categories/Work/Work.md", "Health goals may conflict with work intensity."),
        ("Main Life Categories/Sleep Patterns/Sleep_Patterns__Overview.md", "Main Life Categories/Work/Work.md", "Sleep recovery may conflict with workload patterns."),
    ]

    found = 0
    for a, b, message in checks:
        pa = YOU_DIR / a
        pb = YOU_DIR / b
        if pa.exists() and pb.exists():
            contradictions.append(f"- [Hypothesis] {message} Evidence: [[{Path(a).stem}]] ↔ [[{Path(b).stem}]] Confidence: low")
            found += 1

    if found == 0:
        contradictions.append("- No contradictions detected with current heuristic checks.")

    CONTRADICTIONS_FILE.write_text("\n".join(contradictions) + "\n")
    payload = {
        "scan": True,
        "count": found,
        "contradictions": contradictions[5:] if len(contradictions) > 5 else [],
    }
    if args.json:
        print(json.dumps(payload, indent=2))
    else:
        print(f"✅ Wrote contradictions report: {CONTRADICTIONS_FILE}")
    log_operation("contradictions", {"file": str(CONTRADICTIONS_FILE), "count": found, "json": args.json})
    return 0

