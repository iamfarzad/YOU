#!/bin/bash
# YOU System Setup Script
# Installs YOU CLI to system PATH

set -e

YOU_DIR="$HOME/YOU"
BIN_DIR="$YOU_DIR/bin"
TARGET_BIN="/usr/local/bin/you"

echo "🔧 YOU System Setup"
echo "=================="

# Check if YOU exists
if [ ! -d "$YOU_DIR" ]; then
    echo "❌ YOU directory not found at $YOU_DIR"
    echo "   Clone the repo first: git clone <repo> ~/YOU"
    exit 1
fi

# Make sure bin/you is executable
chmod +x "$BIN_DIR/you"
if [ -f "$BIN_DIR/you-memory" ]; then
    chmod +x "$BIN_DIR/you-memory"
fi

echo "✅ YOU directory found: $YOU_DIR"
echo "✅ CLI script ready: $BIN_DIR/you"
echo ""
echo "To install system-wide:"
echo "  sudo ln -sf $BIN_DIR/you /usr/local/bin/you"
echo ""
echo "Or add to your PATH in ~/.bashrc:"
echo "  export PATH=\"$BIN_DIR:\$PATH\""
echo ""
echo "Usage after install:"
echo "  you ingest --event '...' --energy '-'"
echo "  you capture --source voice --text '...'"
echo "  you process-inbox"
echo "  you refresh-awareness"
echo "  you contradictions"
echo "  you daily-review"
echo "  you obsidian-dashboard"
echo "  you watch --interval 15"
echo "  you daemon --once"
echo "  you demo"
echo "  you recall --query 'investor call pressure' --json"
echo "  you contradictions --scan --json"
echo "  you open-loops --json"
echo "  you-memory recall 'I keep feeling stuck before investor calls'"
echo "  you query --categories work sleep"
echo "  you predict --category work --months 6"
echo "  you lint"
